# Database
DATABASE_URL="postgresql://user:password@localhost:5432/fitview"

# Auth
NEXTAUTH_SECRET="replace_me"
NEXTAUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID="replace_me"
GOOGLE_CLIENT_SECRET="replace_me"

# AI
REPLICATE_API_TOKEN="replace_me"

# Storage
AWS_ACCESS_KEY_ID="replace_me"
AWS_SECRET_ACCESS_KEY="replace_me"
AWS_S3_BUCKET="fitview-uploads"
AWS_REGION="us-east-1"
AWS_S3_ENDPOINT=""
AWS_S3_FORCE_PATH_STYLE="false"
AWS_S3_PUBLIC_BASE_URL=""

# Queue
REDIS_URL="redis://localhost:6379"
PUBLIC_TRYON_RATE_LIMIT="10"
PUBLIC_TRYON_RATE_LIMIT_WINDOW_MS="60000"

# Payments
STRIPE_SECRET_KEY="replace_me"
STRIPE_PUBLISHABLE_KEY="replace_me"
STRIPE_WEBHOOK_SECRET="replace_me"
STRIPE_STARTER_PRICE_ID="replace_me"
STRIPE_PRO_PRICE_ID="replace_me"
STRIPE_ENTERPRISE_PRICE_ID="replace_me"

# Widget CDN
WIDGET_CDN_URL="https://cdn.fitview.ai"
